use std.array

use std.convert

use std.string

use { ViewNode, emptyEvents } from Forui.view

# ── HTML Renderer ───────────────────────────────────────────────────
# Converts a ViewNode tree into an HTML string.
# Render a ViewNode tree to HTML.
def renderToHtml
    @param node ViewNode
    @return String
do
    renderNodeHtml(node, '', false)
end

# Render a ViewNode tree with stable path attributes for DOM patching.
def renderPatchHtml
    @param node ViewNode
    @param path String
    @return String
do
    renderNodeHtml(node, path, true)
end

# Internal renderer used by both plain HTML output and patch-aware output.
# 
# Each component kind emits a `class="fai-<kind>"` attribute; base
# styles live in `forui.css` (shipped by `forai build --html`). User
# modifier styles (padding/background/...) still render inline so they
# override the stylesheet defaults.
def renderNodeHtml
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let kind = node.kind
    if kind == 'Window'
        renderChildrenInternal(node, path, includePath)
    else
        if kind == 'VStack'
            renderDivWithClass(node, path, includePath, 'fai-vstack')
        else
            if kind == 'HStack'
                renderDivWithClass(node, path, includePath, 'fai-hstack')
            else
                if kind == 'ZStack'
                    renderDivWithClass(node, path, includePath, 'fai-zstack')
                else
                    if kind == 'View'
                        renderDivWithClass(node, path, includePath, 'fai-view')
                    else
                        if kind == 'Label'
                            renderLabel(node, path, includePath)
                        else
                            if kind == 'Paragraph'
                                renderParagraph(node, path, includePath)
                            else
                                if kind == 'Heading'
                                    renderHeading(node, path, includePath)
                                else
                                    if kind == 'Button'
                                        renderButton(node, path, includePath)
                                    else
                                        if kind == 'Spacer'
                                            renderSpacer(node, path, includePath)
                                        else
                                            if kind == 'TextInput'
                                                renderTextInput(node, path, includePath)
                                            else
                                                if kind == 'ScrollView'
                                                    renderDivWithClass(node, path, includePath, 'fai-scrollview')
                                                else
                                                    if kind == 'Image'
                                                        renderImage(node, path, includePath)
                                                    else
                                                        if kind == 'Toggle'
                                                            renderToggle(node, path, includePath)
                                                        else
                                                            if kind == 'Divider'
                                                                renderDivider(node, path, includePath)
                                                            else
                                                                if kind == 'SegmentedControl'
                                                                    renderSegmented(node, path, includePath)
                                                                else
                                                                    if kind == 'Router'
                                                                        renderRouter(node, path, includePath)
                                                                    else
                                                                        if kind == 'Link'
                                                                            renderLink(node, path, includePath)
                                                                        else
                                                                            if kind == 'Pre'
                                                                                renderPre(node, path, includePath)
                                                                            else
                                                                                if kind == 'Code'
                                                                                    renderCode(node, path, includePath)
                                                                                else
                                                                                    if kind == 'Span'
                                                                                        renderSpan(node, path, includePath)
                                                                                    else
                                                                                        renderDivWithClass(node, path, includePath, 'fai-view')
                                                                                    end
                                                                                end
                                                                            end
                                                                        end
                                                                    end
                                                                end
                                                            end
                                                        end
                                                    end
                                                end
                                            end
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end
end

# Render children to concatenated HTML.
def renderChildren
    @param node ViewNode
    @return String
do
    renderChildrenInternal(node, '', false)
end

# Render children to concatenated HTML using stable child paths.
def renderChildrenInternal
    @param node ViewNode
    @param parentPath String
    @param includePath Bool
    @return String
do
    var html = ''
    var i = 0
    let childCount = array.length(node.children)
    while i < childCount
        let childPath = childPath(parentPath, i)
        html = html + renderNodeHtml(node.children[i], childPath, includePath)
        i = i + 1
    end
    html
end

# Build a stable dot-path for a child index.
def childPath
    @param parentPath String
    @param index Int
    @return String
do
    if parentPath == ''
        toString(index)
    else
        parentPath + '.' + toString(index)
    end
end

# Build node attributes used by the patch-aware HTML renderer.
def nodeAttrs
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    keyAttr(node) + pathAttr(path, includePath)
end

# Build a data-fai-key attribute string if the node has a key.
def keyAttr
    @param node ViewNode
    @return String
do
    if node.key != ''
        ' data-fai-key="' + node.key + '"'
    else
        ''
    end
end

# Build a data-fai-path attribute string when patch paths are enabled.
def pathAttr
    @param path String
    @param includePath Bool
    @return String
do
    if includePath
        ' data-fai-path="' + path + '"'
    else
        ''
    end
end

# Render a div with a forui class + any user-modifier styles inline.
def renderDivWithClass
    @param node ViewNode
    @param path String
    @param includePath Bool
    @param className String
    @return String
do
    renderTagWithClass(node, path, includePath, 'div', className)
end

# Render a container node as a specific HTML tag, carrying its class,
# style, key, and path attributes. Generalises renderDivWithClass so
# semantic tags (`<pre>`, `<section>`, …) can reuse the same plumbing
# without duplicating the attribute-building boilerplate.
def renderTagWithClass
    @param node ViewNode
    @param path String
    @param includePath Bool
    @param tag String
    @param className String
    @return String
do
    let modStyle = propsToStyle(node.props)
    let children = renderChildrenInternal(node, path, includePath)
    let attrs = nodeAttrs(node, path, includePath)
    var out = '<' + tag + attrs + classAttr(node, className)
    if modStyle != ''
        out = out + ' style="' + modStyle + '"'
    end
    out + '>' + children + '</' + tag + '>'
end

# Build the ` class="..."` attribute for a node, merging the
# framework's kind-specific class with the optional user-supplied
# `cssClass` prop set via the `cssClass` modifier. Returned string
# starts with a leading space so callers can concatenate directly.
def classAttr
    @param node ViewNode
    @param frameworkClass String
    @return String
do
    let userClass = propOr(node.props, 'cssClass', '')
    if userClass == ''
        ' class="' + frameworkClass + '"'
    else
        ' class="' + frameworkClass + ' ' + userClass + '"'
    end
end

# Render a Spacer — flex-grows to fill remaining space in its parent.
def renderSpacer
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let modStyle = propsToStyle(node.props)
    let attrs = nodeAttrs(node, path, includePath)
    var out = '<div' + attrs + ' class="fai-spacer"'
    if modStyle != ''
        out = out + ' style="' + modStyle + '"'
    end
    out + '></div>'
end

# Render a Label.
def renderLabel
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let text = propOr(node.props, 'text', '')
    let style = propsToStyle(node.props)
    let attrs = nodeAttrs(node, path, includePath)
    var out = '<span' + attrs + classAttr(node, 'fai-label')
    if style != ''
        out = out + ' style="' + style + '"'
    end
    out + '>' + text + '</span>'
end

# Render a Paragraph as semantic block prose.
def renderParagraph
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let text = propOr(node.props, 'text', '')
    let style = propsToStyle(node.props)
    let attrs = nodeAttrs(node, path, includePath)
    var out = '<p' + attrs + classAttr(node, 'fai-paragraph')
    if style != ''
        out = out + ' style="' + style + '"'
    end
    out + '>' + text + '</p>'
end

# Render a Heading as h1-h6. Invalid or missing levels fall back to h3.
def renderHeading
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let text = propOr(node.props, 'text', '')
    let style = propsToStyle(node.props)
    let attrs = nodeAttrs(node, path, includePath)
    let tag = headingTag(node)
    var out = '<' + tag + attrs + classAttr(node, 'fai-heading')
    if style != ''
        out = out + ' style="' + style + '"'
    end
    out + '>' + text + '</' + tag + '>'
end

# Return the HTML tag for a Heading node.
def headingTag
    @param node ViewNode
    @return String
do
    var level = 3
    if hasKey(node.props, 'level')
        level = unwrap(getInt(node.props, 'level'), 3)
    end
    if level == 1
        'h1'
    else
        if level == 2
            'h2'
        else
            if level == 4
                'h4'
            else
                if level == 5
                    'h5'
                else
                    if level == 6
                        'h6'
                    else
                        'h3'
                    end
                end
            end
        end
    end
end

# Render a Span leaf. Counterpart to renderLabel — same shape, but a
# `<span class="fai-span">` instead of `<span class="fai-label">`,
# and explicitly designed to carry a `cssClass` to power
# syntax-highlighted token streams (`fai-span tok-kw`, etc.).
def renderSpan
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let text = propOr(node.props, 'text', '')
    let style = propsToStyle(node.props)
    let attrs = nodeAttrs(node, path, includePath)
    var out = '<span' + attrs + classAttr(node, 'fai-span')
    if style != ''
        out = out + ' style="' + style + '"'
    end
    out + '>' + text + '</span>'
end

# Render a Pre — preformatted text container. Emits a semantic
# `<pre>` element so whitespace, font-family, and the platform's
# default monospace styling apply automatically. Modifiers and
# children flow through the same path as VStack/HStack containers.
def renderPre
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    renderTagWithClass(node, path, includePath, 'pre', 'fai-pre')
end

# Render a Code container — `<code class="fai-code">{children}</code>`.
# Children flow through the regular child renderer, so syntax-
# highlighted token streams (`Span` leaves with `cssClass`) render
# as `<span class="fai-span tok-kw">def</span>…` directly inside.
def renderCode
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    renderTagWithClass(node, path, includePath, 'code', 'fai-code')
end

# Render a Button.
def renderButton
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let text = propOr(node.props, 'text', '')
    let modStyle = propsToStyle(node.props)
    var attrs = nodeAttrs(node, path, includePath) + ' class="fai-button"'
    if modStyle != ''
        attrs = attrs + ' style="' + modStyle + '"'
    end
    if hasKey(node.props, 'handlerId')
        let handlerId = toString(getInt(node.props, 'handlerId'))
        attrs = attrs + ' onclick="handleEvent(' + handlerId + ')"'
    end
    '<button' + attrs + '>' + text + '</button>'
end

# Render a TextInput.
def renderTextInput
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let placeholder = propOr(node.props, 'placeholder', '')
    let value = propOr(node.props, 'value', '')
    let inputType = propOr(node.props, 'inputType', 'text')
    let modStyle = propsToStyle(node.props)
    var attrs = nodeAttrs(node, path, includePath) + ' class="fai-textinput"'
    if modStyle != ''
        attrs = attrs + ' style="' + modStyle + '"'
    end
    attrs = attrs + ' placeholder="' + placeholder + '"'
    attrs = attrs + ' value="' + value + '"'
    if hasKey(node.props, 'changeHandlerId')
        let changeId = toString(getInt(node.props, 'changeHandlerId'))
        attrs = attrs + ' oninput="handleInputEvent(' + changeId + ',this.value)"'
    end
    if hasKey(node.props, 'submitHandlerId')
        let submitId = toString(getInt(node.props, 'submitHandlerId'))
        attrs = attrs + ' onkeydown="if(event.key===\'Enter\'){handleSubmitEvent(' + submitId + ')}"'
    end
    '<input type="' + inputType + '"' + attrs + '/>'
end

# Render an Image.
def renderImage
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let src = propOr(node.props, 'src', '')
    let modStyle = propsToStyle(node.props)
    var attrs = nodeAttrs(node, path, includePath) + ' class="fai-image"'
    if modStyle != ''
        attrs = attrs + ' style="' + modStyle + '"'
    end
    '<img' + attrs + ' src="' + src + '"/>'
end

# Render a Toggle. iOS-style track + thumb driven by the data-on attr.
# Click toggles the bound signal via the registered handler.
def renderToggle
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let isOn = propOr(node.props, 'on', 'false')
    let modStyle = propsToStyle(node.props)
    var attrs = nodeAttrs(node, path, includePath) + ' class="fai-toggle"'
    attrs = attrs + ' role="switch"'
    attrs = attrs + ' aria-checked="' + isOn + '"'
    attrs = attrs + ' data-on="' + isOn + '"'
    if modStyle != ''
        attrs = attrs + ' style="' + modStyle + '"'
    end
    if hasKey(node.props, 'handlerId')
        let handlerId = toString(getInt(node.props, 'handlerId'))
        attrs = attrs + ' onclick="handleEvent(' + handlerId + ')"'
    end
    '<button' + attrs + '></button>'
end

# Render a Divider — a 1px horizontal rule.
def renderDivider
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let modStyle = propsToStyle(node.props)
    var attrs = nodeAttrs(node, path, includePath) + ' class="fai-divider"'
    if modStyle != ''
        attrs = attrs + ' style="' + modStyle + '"'
    end
    '<hr' + attrs + '/>'
end

# Render a SegmentedControl. Each child is a Segment (see view.fai)
# whose props carry `text`, `selected`, and optional `handlerId`.
def renderSegmented
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let modStyle = propsToStyle(node.props)
    var out = '<div' + nodeAttrs(node, path, includePath) + ' class="fai-segmented"'
    if modStyle != ''
        out = out + ' style="' + modStyle + '"'
    end
    out = out + ' role="tablist">'
    var i = 0
    let childCount = array.length(node.children)
    while i < childCount
        let child = node.children[i]
        let segPath = childPath(path, i)
        out = out + renderSegment(child, segPath, includePath)
        i = i + 1
    end
    out + '</div>'
end

# Render a single Segment child of a SegmentedControl.
def renderSegment
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let text = propOr(node.props, 'text', '')
    let selected = propOr(node.props, 'selected', 'false')
    var attrs = nodeAttrs(node, path, includePath) + ' class="fai-segment"'
    attrs = attrs + ' role="tab"'
    attrs = attrs + ' data-selected="' + selected + '"'
    attrs = attrs + ' aria-selected="' + selected + '"'
    if hasKey(node.props, 'handlerId')
        let handlerId = toString(getInt(node.props, 'handlerId'))
        attrs = attrs + ' onclick="handleEvent(' + handlerId + ')"'
    end
    '<button' + attrs + '>' + text + '</button>'
end

# ── Router & Link ──────────────────────────────────────────────────
# Render a Router container with a transition data attribute.
# Children are the matched route's content.
def renderRouter
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let transition = propOr(node.props, 'transition', 'none')
    let modStyle = propsToStyle(node.props)
    let children = renderChildrenInternal(node, path, includePath)
    let attrs = nodeAttrs(node, path, includePath)
    var out = '<div' + attrs + ' class="fai-router" data-transition="' + transition + '"'
    if modStyle != ''
        out = out + ' style="' + modStyle + '"'
    end
    out + '>' + children + '</div>'
end

# Render a Link as an <a> tag. The href enables right-click "open in
# new tab", keyboard navigation, and accessibility. The onclick
# intercepts for client-side navigation via the router.
def renderLink
    @param node ViewNode
    @param path String
    @param includePath Bool
    @return String
do
    let to = propOr(node.props, 'to', '/')
    let modStyle = propsToStyle(node.props)
    let children = renderChildrenInternal(node, path, includePath)
    var attrs = nodeAttrs(node, path, includePath) + ' class="fai-link"'
    attrs = attrs + ' href="' + to + '"'
    if modStyle != ''
        attrs = attrs + ' style="' + modStyle + '"'
    end
    if hasKey(node.props, 'handlerId')
        let handlerId = toString(getInt(node.props, 'handlerId'))
        attrs = attrs + ' onclick="event.preventDefault();handleEvent(' + handlerId + ')"'
    end
    '<a' + attrs + '>' + children + '</a>'
end

# ── Style helpers ───────────────────────────────────────────────────
# Convert modifier props to a CSS style string.
def propsToStyle
    @param props Dictionary
    @return String
do
    var style = ''
    if hasKey(props, 'padding')
        style = style + 'padding:' + toString(getInt(props, 'padding')) + 'px;'
    end
    if hasKey(props, 'paddingTop')
        style = style + 'padding-top:' + toString(getInt(props, 'paddingTop')) + 'px;'
    end
    if hasKey(props, 'paddingRight')
        style = style + 'padding-right:' + toString(getInt(props, 'paddingRight')) + 'px;'
    end
    if hasKey(props, 'paddingBottom')
        style = style + 'padding-bottom:' + toString(getInt(props, 'paddingBottom')) + 'px;'
    end
    if hasKey(props, 'paddingLeft')
        style = style + 'padding-left:' + toString(getInt(props, 'paddingLeft')) + 'px;'
    end
    if hasKey(props, 'margin')
        style = style + 'margin:' + toString(getInt(props, 'margin')) + 'px;'
    end
    if hasKey(props, 'marginTop')
        style = style + 'margin-top:' + toString(getInt(props, 'marginTop')) + 'px;'
    end
    if hasKey(props, 'marginRight')
        style = style + 'margin-right:' + toString(getInt(props, 'marginRight')) + 'px;'
    end
    if hasKey(props, 'marginBottom')
        style = style + 'margin-bottom:' + toString(getInt(props, 'marginBottom')) + 'px;'
    end
    if hasKey(props, 'marginLeft')
        style = style + 'margin-left:' + toString(getInt(props, 'marginLeft')) + 'px;'
    end
    if hasKey(props, 'centered')
        style = style + 'margin-left:auto;margin-right:auto;'
    end
    if hasKey(props, 'background')
        let bg = getString(props, 'background')
        style = style + 'background:' + unwrap(bg, '') + ';'
    end
    if hasKey(props, 'foreground')
        let fg = getString(props, 'foreground')
        style = style + 'color:' + unwrap(fg, '') + ';'
    end
    if hasKey(props, 'cornerRadius')
        style = style + 'border-radius:' + toString(getInt(props, 'cornerRadius')) + 'px;'
    end
    if hasKey(props, 'borderWidth')
        let bc = getString(props, 'borderColor')
        style = style + 'border:' + toString(getInt(props, 'borderWidth')) + 'px solid ' + unwrap(bc, 'currentColor') + ';'
    end
    if hasKey(props, 'borderLeftWidth')
        let blc = getString(props, 'borderLeftColor')
        style = style + 'border-left:' + toString(getInt(props, 'borderLeftWidth')) + 'px solid ' + unwrap(blc, 'currentColor') + ';'
    end
    if hasKey(props, 'fontSize')
        style = style + 'font-size:' + toString(getInt(props, 'fontSize')) + 'px;'
    end
    if hasKey(props, 'fontWeight')
        let fw = getString(props, 'fontWeight')
        style = style + 'font-weight:' + unwrap(fw, '') + ';'
    end
    if hasKey(props, 'lineHeight')
        let lh = getString(props, 'lineHeight')
        style = style + 'line-height:' + unwrap(lh, '') + ';'
    end
    if hasKey(props, 'fontStyle')
        let fs = getString(props, 'fontStyle')
        style = style + 'font-style:' + unwrap(fs, '') + ';'
    end
    if hasKey(props, 'letterSpacing')
        let ls = getString(props, 'letterSpacing')
        style = style + 'letter-spacing:' + unwrap(ls, '') + ';'
    end
    if hasKey(props, 'textAlign')
        let ta = getString(props, 'textAlign')
        style = style + 'text-align:' + unwrap(ta, '') + ';'
    end
    if hasKey(props, 'fontFamily')
        let ff = getString(props, 'fontFamily')
        style = style + 'font-family:' + unwrap(ff, '') + ';'
    end
    if hasKey(props, 'opacity')
        style = style + 'opacity:' + toString(getInt(props, 'opacity')) + ';'
    end
    if hasKey(props, 'flex')
        let fl = getString(props, 'flex')
        style = style + 'flex:' + unwrap(fl, '') + ';'
    end
    if hasKey(props, 'alignItems')
        let ai = getString(props, 'alignItems')
        style = style + 'align-items:' + unwrap(ai, '') + ';'
    end
    if hasKey(props, 'justifyContent')
        let jc = getString(props, 'justifyContent')
        style = style + 'justify-content:' + unwrap(jc, '') + ';'
    end
    if hasKey(props, 'flexWrap')
        let fw = getString(props, 'flexWrap')
        style = style + 'flex-wrap:' + unwrap(fw, '') + ';'
    end
    if hasKey(props, 'gap')
        style = style + 'gap:' + toString(getInt(props, 'gap')) + 'px;'
    end
    if hasKey(props, 'alignSelf')
        let asv = getString(props, 'alignSelf')
        style = style + 'align-self:' + unwrap(asv, '') + ';'
    end
    if hasKey(props, 'display')
        let d = getString(props, 'display')
        style = style + 'display:' + unwrap(d, '') + ';'
    end
    if hasKey(props, 'width')
        let w = getString(props, 'width')
        style = style + 'width:' + unwrap(w, '') + ';'
    end
    if hasKey(props, 'minWidth')
        let mw = getString(props, 'minWidth')
        style = style + 'min-width:' + unwrap(mw, '') + ';'
    end
    if hasKey(props, 'height')
        let h = getString(props, 'height')
        style = style + 'height:' + unwrap(h, '') + ';'
    end
    if hasKey(props, 'minHeight')
        let mh = getString(props, 'minHeight')
        style = style + 'min-height:' + unwrap(mh, '') + ';'
    end
    if hasKey(props, 'maxWidth')
        let mw = getString(props, 'maxWidth')
        style = style + 'max-width:' + unwrap(mw, '') + ';'
    end
    if hasKey(props, 'position')
        let pos = getString(props, 'position')
        style = style + 'position:' + unwrap(pos, '') + ';'
    end
    if hasKey(props, 'top')
        style = style + 'top:' + toString(getInt(props, 'top')) + 'px;'
    end
    if hasKey(props, 'zIndex')
        style = style + 'z-index:' + toString(getInt(props, 'zIndex')) + ';'
    end
    style
end

# Get a string prop with a default.
def propOr
    @param props Dictionary
    @param key String
    @param fallback String
    @return String
do
    let val = getString(props, key)
    unwrap(val, fallback)
end

# ── Tests ───────────────────────────────────────────────────────────
# Minimal ViewNode for tests.
def testNode
    @param kind String
    @param props Dictionary
    @param children ViewNode[]
    @return ViewNode
do
    ViewNode(kind: kind, key: '', props: props, children: children, events: emptyEvents())
end

# Leaf node.
def leaf
    @param kind String
    @param props Dictionary
    @return ViewNode
do
    testNode(kind, props, [])
end

test renderLabel
    it 'renders a label as a class-bearing span'
        let node = leaf('Label', set({}, 'text', 'hello'))
        let html = renderToHtml(node)
        assert.equals(html, '<span class="fai-label">hello</span>')
    end
    it 'renders a label with modifier style inline'
        let props = set(set({}, 'text', 'styled'), 'fontSize', 24)
        let node = leaf('Label', props)
        let html = renderToHtml(node)
        assert.equals(html, '<span class="fai-label" style="font-size:24px;">styled</span>')
    end
end

test renderParagraph
    it 'renders a paragraph as a class-bearing p'
        let node = leaf('Paragraph', set({}, 'text', 'body'))
        let html = renderToHtml(node)
        assert.equals(html, '<p class="fai-paragraph">body</p>')
    end
    it 'preserves cssClass and modifiers'
        let props = set(set(set({}, 'text', 'body'), 'cssClass', 'intro'), 'lineHeight', '1.65')
        let node = leaf('Paragraph', props)
        let html = renderToHtml(node)
        assert.equals(html, '<p class="fai-paragraph intro" style="line-height:1.65;">body</p>')
