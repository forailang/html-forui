test renderToHtml
    it 'renders a spacer with fai-spacer class'
        let node = leaf('Spacer', {})
        let html = renderToHtml(node)
        assert.equals(html, '<div class="fai-spacer"></div>')
    end
end

test renderToHtml
    it 'renders a text input with default type'
        let node = leaf('TextInput', set({}, 'placeholder', 'Type here...'))
        let html = renderToHtml(node)
        assert.equals(html, '<input type="text" class="fai-textinput" placeholder="Type here..." value=""/>')
    end
    it 'renders inputType from props'
        let props = set(set({}, 'placeholder', 'you@example.com'), 'inputType', 'email')
        let node = leaf('TextInput', props)
        let html = renderToHtml(node)
        assert.equals(html, '<input type="email" class="fai-textinput" placeholder="you@example.com" value=""/>')
    end
    it 'renders password inputType'
        let props = set(set({}, 'placeholder', 'Password'), 'inputType', 'password')
        let node = leaf('TextInput', props)
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'type="password"'), true)
    end
    it 'emits onkeydown enter handler when submitHandlerId is set'
        let props = set(set(set({}, 'placeholder', 'x'), 'inputType', 'text'), 'submitHandlerId', 7)
        let node = leaf('TextInput', props)
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'onkeydown="if(event.key===\'Enter\'){handleSubmitEvent(7)}"'), true)
    end
    it 'omits onkeydown when submitHandlerId is absent'
        let node = leaf('TextInput', set({}, 'placeholder', 'x'))
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'onkeydown'), false)
    end
end

test renderToHtml
    it 'renders padding and background as inline style so user modifiers win'
        let props = set(set(set({}, 'text', 'styled'), 'padding', 10), 'background', 'blue')
        let node = leaf('Label', props)
        let html = renderToHtml(node)
        assert.equals(html, '<span class="fai-label" style="padding:10px;background:blue;">styled</span>')
    end
end

test renderToHtml
    it 'renders a Toggle with data-on=false by default'
        let node = leaf('Toggle', {})
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'class="fai-toggle"'), true)
        assert.equals(string.contains(html, 'data-on="false"'), true)
        assert.equals(string.contains(html, 'role="switch"'), true)
    end
    it 'renders a Toggle with data-on=true when on prop is true'
        let node = leaf('Toggle', set({}, 'on', 'true'))
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'data-on="true"'), true)
        assert.equals(string.contains(html, 'aria-checked="true"'), true)
    end
end

test renderToHtml
    it 'renders a Divider as an hr with class'
        let node = leaf('Divider', {})
        let html = renderToHtml(node)
        assert.equals(html, '<hr class="fai-divider"/>')
    end
end

test renderToHtml
    it 'renders a SegmentedControl with segments'
        let seg1 = leaf('Segment', set(set({}, 'text', 'Day'), 'selected', 'true'))
        let seg2 = leaf('Segment', set(set({}, 'text', 'Week'), 'selected', 'false'))
        let node = testNode('SegmentedControl', {}, [seg1 seg2])
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'class="fai-segmented"'), true)
        assert.equals(string.contains(html, 'class="fai-segment"'), true)
        assert.equals(string.contains(html, 'data-selected="true"'), true)
        assert.equals(string.contains(html, 'data-selected="false"'), true)
        assert.equals(string.contains(html, '>Day<'), true)
        assert.equals(string.contains(html, '>Week<'), true)
    end
end

test renderRouter
    it 'renders a Router with transition attribute'
        let child = leaf('Label', set({}, 'text', 'Home'))
        let props = set(set({}, 'transition', 'fade'), 'currentPath', '/')
        let node = testNode('Router', props, [child])
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'class="fai-router"'), true)
        assert.equals(string.contains(html, 'data-transition="fade"'), true)
        assert.equals(string.contains(html, '>Home<'), true)
    end
    it 'defaults transition to none'
        let node = testNode('Router', {}, [])
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'data-transition="none"'), true)
    end
end

test renderLink
    it 'renders a Link as an anchor tag with href'
        let child = leaf('Label', set({}, 'text', 'Settings'))
        let props = set(set({}, 'to', '/settings'), 'handlerId', 5)
        let node = testNode('Link', props, [child])
        let html = renderToHtml(node)
        assert.equals(string.contains(html, '<a'), true)
        assert.equals(string.contains(html, 'href="/settings"'), true)
        assert.equals(string.contains(html, 'class="fai-link"'), true)
        assert.equals(string.contains(html, 'event.preventDefault()'), true)
        assert.equals(string.contains(html, '>Settings<'), true)
    end
    it 'renders a Link without handler when no handlerId'
        let props = set({}, 'to', '/about')
        let node = testNode('Link', props, [])
        let html = renderToHtml(node)
        assert.equals(string.contains(html, 'href="/about"'), true)
        assert.equals(string.contains(html, 'onclick'), false)
    end
end

test renderPatchHtml
    it 'renders path attributes for subtree patching'
        let node = testNode('VStack', {}, [
            leaf('Label', set({}, 'text', 'one'))
            leaf('Button', set({}, 'text', 'two'))
        ])
        let html = renderPatchHtml(node, '3')
        assert.equals(html, '<div data-fai-path="3" class="fai-vstack"><span data-fai-path="3.0" class="fai-label">one</span><button data-fai-path="3.1" class="fai-button">two</button></div>')
    end
    it 'keeps keyed nodes and paths together'
        let node = ViewNode(kind: 'Label', key: 'item-1', props: set({}, 'text', 'hello'), children: [], events: emptyEvents())
        let html = renderPatchHtml(node, '0')
        assert.equals(html, '<span data-fai-key="item-1" data-fai-path="0" class="fai-label">hello</span>')
    end
end

test testNode
    it 'builds a ViewNode with the given kind, props, and children'
        let n = testNode('VStack', {}, [])
        assert.equals(n.kind, 'VStack')
        assert.equals(n.key, '')
        assert.equals(array.length(n.children), 0)
    end
end

test leaf
    it 'builds a childless ViewNode'
        let n = leaf('Label', set({}, 'text', 'x'))
        assert.equals(n.kind, 'Label')
        assert.equals(array.length(n.children), 0)
        assert.equals(getString(n.props, 'text')!, 'x')
    end
end

test propOr
    it 'returns the stored string when the key exists'
        let p = set({}, 'text', 'hi')
        assert.equals(propOr(p, 'text', 'fallback'), 'hi')
    end
    it 'returns the fallback when the key is missing'
        assert.equals(propOr({}, 'text', 'fallback'), 'fallback')
    end
end

test propsToStyle
    it 'produces empty style for empty props'
        assert.equals(propsToStyle({}), '')
    end
    it 'emits padding as px'
        assert.equals(propsToStyle(set({}, 'padding', 12)), 'padding:12px;')
    end
    it 'emits per-side padding as px'
        let p = set(set(set(set({}, 'paddingTop', 1), 'paddingRight', 2), 'paddingBottom', 3), 'paddingLeft', 4)
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'padding-top:1px;'), true)
        assert.equals(string.contains(style, 'padding-right:2px;'), true)
        assert.equals(string.contains(style, 'padding-bottom:3px;'), true)
        assert.equals(string.contains(style, 'padding-left:4px;'), true)
    end
    it 'emits margin as px'
        assert.equals(propsToStyle(set({}, 'margin', 16)), 'margin:16px;')
    end
    it 'emits per-side margin as px'
        let p = set(set(set(set({}, 'marginTop', 1), 'marginRight', 2), 'marginBottom', 3), 'marginLeft', 4)
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'margin-top:1px;'), true)
        assert.equals(string.contains(style, 'margin-right:2px;'), true)
        assert.equals(string.contains(style, 'margin-bottom:3px;'), true)
        assert.equals(string.contains(style, 'margin-left:4px;'), true)
    end
    it 'emits background and foreground colour'
        let p = set(set({}, 'background', '#000'), 'foreground', '#fff')
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'background:#000;'), true)
        assert.equals(string.contains(style, 'color:#fff;'), true)
    end
    it 'emits border as a solid CSS shorthand'
        let p = set(set({}, 'borderWidth', 2), 'borderColor', '#e0e6ec')
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'border:2px solid #e0e6ec;'), true)
    end
    it 'emits left border as a solid CSS shorthand'
        let p = set(set({}, 'borderLeftWidth', 2), 'borderLeftColor', '#dde5dc')
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'border-left:2px solid #dde5dc;'), true)
    end
    it 'emits flex alignment styles'
        var p = set({}, 'alignItems', 'stretch')
        p = set(p, 'justifyContent', 'flex-end')
        p = set(p, 'flexWrap', 'wrap')
        p = set(p, 'gap', 24)
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'align-items:stretch;'), true)
        assert.equals(string.contains(style, 'justify-content:flex-end;'), true)
        assert.equals(string.contains(style, 'flex-wrap:wrap;'), true)
        assert.equals(string.contains(style, 'gap:24px;'), true)
    end
    it 'emits child and sizing styles'
        var p = set({}, 'alignSelf', 'stretch')
        p = set(p, 'display', 'block')
        p = set(p, 'minWidth', '240px')
        p = set(p, 'height', '100%')
        p = set(p, 'minHeight', '100vh')
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'align-self:stretch;'), true)
        assert.equals(string.contains(style, 'display:block;'), true)
        assert.equals(string.contains(style, 'min-width:240px;'), true)
        assert.equals(string.contains(style, 'height:100%;'), true)
        assert.equals(string.contains(style, 'min-height:100vh;'), true)
    end
    it 'emits typography helper styles'
        var p = set({}, 'lineHeight', '1.65')
        p = set(p, 'fontStyle', 'italic')
        p = set(p, 'letterSpacing', '0.02em')
        p = set(p, 'textAlign', 'left')
        p = set(p, 'fontFamily', 'Inter, sans-serif')
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'line-height:1.65;'), true)
        assert.equals(string.contains(style, 'font-style:italic;'), true)
        assert.equals(string.contains(style, 'letter-spacing:0.02em;'), true)
        assert.equals(string.contains(style, 'text-align:left;'), true)
        assert.equals(string.contains(style, 'font-family:Inter, sans-serif;'), true)
    end
    it 'emits positioning and centered styles'
        var p = set({}, 'position', 'sticky')
        p = set(p, 'top', 0)
        p = set(p, 'zIndex', 20)
        p = set(p, 'centered', 'true')
        let style = propsToStyle(p)
        assert.equals(string.contains(style, 'position:sticky;'), true)
        assert.equals(string.contains(style, 'top:0px;'), true)
        assert.equals(string.contains(style, 'z-index:20;'), true)
        assert.equals(string.contains(style, 'margin-left:auto;'), true)
        assert.equals(string.contains(style, 'margin-right:auto;'), true)
    end
end

test childPath
    it 'is the index at the root'
        assert.equals(childPath('', 2), '2')
    end
    it 'dots the index onto a non-root parent'
        assert.equals(childPath('1', 3), '1.3')
    end
end

test keyAttr
    it 'is empty for a keyless node'
        assert.equals(keyAttr(leaf('Label', {})), '')
    end
    it 'carries the data-fai-key when the node has a key'
        let n = ViewNode(kind: 'Label', key: 'row-7', props: {}, children: [], events: emptyEvents())
        assert.equals(keyAttr(n), ' data-fai-key="row-7"')
    end
end

test pathAttr
    it 'is empty when includePath is false'
        assert.equals(pathAttr('0.1', false), '')
    end
    it 'emits data-fai-path when includePath is true'
        assert.equals(pathAttr('0.1', true), ' data-fai-path="0.1"')
    end
end

test nodeAttrs
    it 'combines key and path attributes'
        let n = ViewNode(kind: 'Label', key: 'k', props: {}, children: [], events: emptyEvents())
        assert.equals(nodeAttrs(n, '1', true), ' data-fai-key="k" data-fai-path="1"')
    end
    it 'is the empty string for a keyless node with includePath off'
        assert.equals(nodeAttrs(leaf('Label', {}), '1', false), '')
    end
end

test renderDivWithClass
    it 'emits the class on a <div> wrapper'
        let n = testNode('View', {}, [])
        let html = renderDivWithClass(n, '', false, 'fai-view')
        assert.equals(html, '<div class="fai-view"></div>')
    end
    it 'folds modifier styles into inline style'
        let n = testNode('View', set({}, 'padding', 8), [])
        let html = renderDivWithClass(n, '', false, 'fai-view')
        assert.equals(string.contains(html, 'style="padding:8px;"'), true)
    end
end

test renderTagWithClass
    it 'emits the requested tag with the requested class'
        let n = testNode('View', {}, [])
        let html = renderTagWithClass(n, '', false, 'section', 'fai-section')
        assert.equals(html, '<section class="fai-section"></section>')
    end
    it 'closes with a matching tag for non-div elements'
        let inner = leaf('Code', set({}, 'text', 'x'))
        let n = testNode('Pre', set({}, 'background', '#1b1b1b'), [inner])
        let html = renderTagWithClass(n, '', false, 'pre', 'fai-pre')
        assert.equals(string.contains(html, '<pre class="fai-pre"'), true)
        assert.equals(string.contains(html, '</pre>'), true)
        assert.equals(string.contains(html, 'style="background:#1b1b1b;"'), true)
    end
end

test renderPre
    it 'renders a Pre node as a semantic <pre class="fai-pre"> wrapper'
        let inner = leaf('Span', set({}, 'text', 'let x = 1'))
        let code = testNode('Code', {}, [inner])
        let n = testNode('Pre', {}, [code])
        let html = renderPre(n, '', false)
        assert.equals(html, '<pre class="fai-pre"><code class="fai-code"><span class="fai-span">let x = 1</span></code></pre>')
    end
    it 'carries modifier styles as inline style on <pre>'
        let n = testNode('Pre', set({}, 'padding', 16), [])
        let html = renderPre(n, '', false)
        assert.equals(string.contains(html, '<pre class="fai-pre" style="padding:16px;">'), true)
    end
end

test renderCode
    it 'renders a Code container with its children inside <code>'
        let label = leaf('Label', set({}, 'text', 'fai run'))
        let n = testNode('Code', {}, [label])
        let html = renderCode(n, '', false)
        assert.equals(html, '<code class="fai-code"><span class="fai-label">fai run</span></code>')
    end
    it 'wraps a sequence of Span tokens for highlighted code'
        let kw = leaf('Span', set(set({}, 'text', 'def'), 'cssClass', 'tok-kw'))
        let plain = leaf('Span', set({}, 'text', ' add'))
        let n = testNode('Code', {}, [kw plain])
        let html = renderCode(n, '', false)
        assert.equals(html, '<code class="fai-code"><span class="fai-span tok-kw">def</span><span class="fai-span"> add</span></code>')
    end
    it 'folds modifier styles into the <code> tag'
        let n = testNode('Code', set({}, 'fontSize', 13), [])
        let html = renderCode(n, '', false)
        assert.equals(html, '<code class="fai-code" style="font-size:13px;"></code>')
    end
    it 'appends a user cssClass to the framework class'
        let n = testNode('Code', set({}, 'cssClass', 'shellcmd'), [])
        let html = renderCode(n, '', false)
        assert.equals(html, '<code class="fai-code shellcmd"></code>')
    end
end

test renderSpan
    it 'renders a Span leaf as a <span class="fai-span">'
        let n = leaf('Span', set({}, 'text', 'def'))
        let html = renderSpan(n, '', false)
        assert.equals(html, '<span class="fai-span">def</span>')
    end
    it 'merges a token cssClass into the class attribute'
        let props = set(set({}, 'text', 'def'), 'cssClass', 'tok-kw')
        let n = leaf('Span', props)
        let html = renderSpan(n, '', false)
        assert.equals(html, '<span class="fai-span tok-kw">def</span>')
    end
    it 'preserves inline modifier styles alongside the merged class'
        let props = set(set(set({}, 'text', 'styled'), 'cssClass', 'tok-fn'), 'foreground', '#f472b6')
        let n = leaf('Span', props)
        let html = renderSpan(n, '', false)
        assert.equals(html, '<span class="fai-span tok-fn" style="color:#f472b6;">styled</span>')
    end
end

test classAttr
    it 'omits the user class when cssClass is absent'
        let n = leaf('Span', set({}, 'text', 'x'))
        assert.equals(classAttr(n, 'fai-span'), ' class="fai-span"')
    end
    it 'appends the user class when cssClass is present'
        let n = leaf('Span', set(set({}, 'text', 'x'), 'cssClass', 'tok-kw'))
        assert.equals(classAttr(n, 'fai-span'), ' class="fai-span tok-kw"')
    end
    it 'omits the user class when cssClass is the empty string'
        let n = leaf('Span', set(set({}, 'text', 'x'), 'cssClass', ''))
        assert.equals(classAttr(n, 'fai-span'), ' class="fai-span"')
    end
end

test renderNodeHtml
    it 'dispatches Paragraph and Heading through renderNodeHtml'
        let para = leaf('Paragraph', set({}, 'text', 'copy'))
        let head = leaf('Heading', set(set({}, 'text', 'Title'), 'level', 2))
        assert.equals(renderNodeHtml(para, '', false), '<p class="fai-paragraph">copy</p>')
        assert.equals(renderNodeHtml(head, '', false), '<h2 class="fai-heading">Title</h2>')
    end
    it 'dispatches Pre + Code through renderNodeHtml end-to-end'
        let span = leaf('Span', set({}, 'text', 'curl -fsSL ...'))
        let code = testNode('Code', {}, [span])
        let outer = testNode('Pre', {}, [code])
        let html = renderToHtml(outer)
        assert.equals(html, '<pre class="fai-pre"><code class="fai-code"><span class="fai-span">curl -fsSL ...</span></code></pre>')
    end
    it 'dispatches Span with cssClass through renderNodeHtml'
        let kw = leaf('Span', set(set({}, 'text', 'def'), 'cssClass', 'tok-kw'))
        let sp = leaf('Span', set({}, 'text', ' add'))
        let outer = testNode('Pre', {}, [kw sp])
        let html = renderToHtml(outer)
        assert.equals(html, '<pre class="fai-pre"><span class="fai-span tok-kw">def</span><span class="fai-span"> add</span></pre>')
    end
end

test renderSpacer
    it 'emits an empty spacer div'
        assert.equals(renderSpacer(leaf('Spacer', {}), '', false), '<div class="fai-spacer"></div>')
    end
end

test renderButton
    it 'emits a <button> carrying the text'
        let n = leaf('Button', set({}, 'text', 'Save'))
        assert.equals(renderButton(n, '', false), '<button class="fai-button">Save</button>')
    end
    it 'wires onclick when the node has a handlerId'
        let n = leaf('Button', set(set({}, 'text', 'Go'), 'handlerId', 3))
        assert.equals(string.contains(renderButton(n, '', false), 'onclick="handleEvent(3)"'), true)
    end
end

test renderTextInput
    it 'emits an <input> with placeholder and value'
        let p = set(set({}, 'placeholder', 'Search'), 'value', 'foo')
        let n = leaf('TextInput', p)
        let html = renderTextInput(n, '', false)
        assert.equals(string.contains(html, 'placeholder="Search"'), true)
        assert.equals(string.contains(html, 'value="foo"'), true)
    end
    it 'defaults the input type to text'
        let n = leaf('TextInput', {})
        assert.equals(string.startsWith(renderTextInput(n, '', false), '<input type="text"'), true)
    end
end

test renderImage
    it 'emits an <img> with src'
        let n = leaf('ImageView', set({}, 'src', '/logo.png'))
        assert.equals(renderImage(n, '', false), '<img class="fai-image" src="/logo.png"/>')
    end
end

test renderToggle
    it 'emits a <button> carrying aria + data-on'
        let n = leaf('Toggle', set({}, 'on', 'true'))
        let html = renderToggle(n, '', false)
        assert.equals(string.contains(html, 'aria-checked="true"'), true)
        assert.equals(string.contains(html, 'data-on="true"'), true)
    end
end

test renderDivider
    it 'emits an <hr>'
        assert.equals(renderDivider(leaf('Divider', {}), '', false), '<hr class="fai-divider"/>')
    end
end

test renderSegment
    it 'emits a segment <button> with selected + text'
        let p = set(set({}, 'text', 'Day'), 'selected', 'true')
        let html = renderSegment(leaf('Segment', p), '', false)
        assert.equals(string.contains(html, 'data-selected="true"'), true)
        assert.equals(string.contains(html, '>Day</button>'), true)
    end
end

test renderSegmented
    it 'wraps children segments inside a tablist div'
        let children = [
            leaf('Segment', set({}, 'text', 'A'))
            leaf('Segment', set({}, 'text', 'B'))
        ]
        let html = renderSegmented(testNode('SegmentedControl', {}, children), '', false)
        assert.equals(string.contains(html, 'role="tablist"'), true)
        assert.equals(string.contains(html, '>A</button>'), true)
        assert.equals(string.contains(html, '>B</button>'), true)
    end
end

test renderChildren
    it 'concatenates child HTML without path attrs'
        let parent = testNode('VStack', {}, [
            leaf('Label', set({}, 'text', 'a'))
            leaf('Label', set({}, 'text', 'b'))
        ])
        let html = renderChildren(parent)
        assert.equals(html, '<span class="fai-label">a</span><span class="fai-label">b</span>')
    end
end

test renderChildrenInternal
    it 'dots child indices onto the parent path when includePath is on'
        let parent = testNode('VStack', {}, [
            leaf('Label', set({}, 'text', 'a'))
        ])
        let html = renderChildrenInternal(parent, '5', true)
        assert.equals(string.contains(html, 'data-fai-path="5.0"'), true)
    end
end

test renderNodeHtml
    it 'routes a Label node to renderLabel'
        let n = leaf('Label', set({}, 'text', 'x'))
        assert.equals(renderNodeHtml(n, '', false), '<span class="fai-label">x</span>')
    end
    it 'wraps an unknown kind in a generic fai-view div'
        let n = testNode('Mystery', {}, [])
        assert.equals(renderNodeHtml(n, '', false), '<div class="fai-view"></div>')
    end
end
