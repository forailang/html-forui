test renderHeading
    it 'renders a heading as h3 by default'
        let node = leaf('Heading', set({}, 'text', 'Section'))
        let html = renderToHtml(node)
        assert.equals(html, '<h3 class="fai-heading">Section</h3>')
    end
    it 'renders an explicit heading level'
        let props = set(set({}, 'text', 'Page'), 'level', 1)
        let node = leaf('Heading', props)
        let html = renderToHtml(node)
        assert.equals(html, '<h1 class="fai-heading">Page</h1>')
    end
    it 'falls back to h3 for invalid heading levels'
        let props = set(set({}, 'text', 'Bad'), 'level', 9)
        let node = leaf('Heading', props)
        let html = renderToHtml(node)
        assert.equals(html, '<h3 class="fai-heading">Bad</h3>')
    end
    it 'preserves cssClass and modifiers'
        let props = set(set(set({}, 'text', 'Section'), 'cssClass', 'hero-title'), 'fontSize', 42)
        let node = leaf('Heading', props)
        let html = renderToHtml(node)
        assert.equals(html, '<h3 class="fai-heading hero-title" style="font-size:42px;">Section</h3>')
    end
end

test headingTag
    it 'maps heading levels to tags'
        let h1 = leaf('Heading', set(set({}, 'text', 'Page'), 'level', 1))
        let h3 = leaf('Heading', set({}, 'text', 'Default'))
        let bad = leaf('Heading', set(set({}, 'text', 'Bad'), 'level', 9))
        assert.equals(headingTag(h1), 'h1')
        assert.equals(headingTag(h3), 'h3')
        assert.equals(headingTag(bad), 'h3')
    end
end

test renderToHtml
    it 'renders a button with the fai-button class (base style lives in forui.css)'
        let node = leaf('Button', set({}, 'text', 'Click'))
        let html = renderToHtml(node)
        assert.equals(html, '<button class="fai-button">Click</button>')
    end
end

